<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>生成完成</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
      min-height: 100vh;
      color: #fff;
      padding: 20px;
    }
    .container { max-width: 500px; margin: 0 auto; }
    .header { text-align: center; padding: 30px 0 20px; }
    .header h1 { font-size: 28px; }
    .header p { color: #aaa; font-size: 14px; margin-top: 8px; }
    .card {
      background: rgba(255,255,255,0.08);
      border-radius: 16px;
      padding: 24px;
      margin-bottom: 16px;
      backdrop-filter: blur(10px);
    }
    .file-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 0;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .file-item:last-child { border-bottom: none; }
    .bpm-label {
      font-size: 20px;
      font-weight: bold;
      color: #4ecdc4;
    }
    .file-name {
      font-size: 12px;
      color: #888;
      margin-top: 4px;
    }
    .actions { display: flex; gap: 8px; }
    .btn {
      padding: 8px 20px;
      border-radius: 20px;
      border: none;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
    }
    .btn-play {
      background: #4ecdc4;
      color: #fff;
    }
    .btn-download {
      background: rgba(255,255,255,0.1);
      color: #fff;
      border: 1px solid rgba(255,255,255,0.2);
    }
    .btn-download:hover { background: rgba(255,255,255,0.2); }
    .btn-back {
      display: block;
      width: 100%;
      height: 48px;
      background: rgba(255,255,255,0.06);
      color: #aaa;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 24px;
      font-size: 16px;
      cursor: pointer;
      text-align: center;
      line-height: 48px;
      text-decoration: none;
      margin-top: 16px;
    }
    .btn-back:hover { background: rgba(255,255,255,0.1); }
    .footer { text-align: center; padding: 30px; color: #555; font-size: 12px; }
    audio { display: none; }
    .playing .btn-play { background: #ff6b6b; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>✅ 生成完成！</h1>
      <p><%= baseName %></p>
    </div>

    <div class="card">
      <% results.forEach(function(r) { %>
      <div class="file-item">
        <div>
          <div class="bpm-label"><%= r.bpm %> BPM</div>
          <div class="file-name"><%= r.name %></div>
        </div>
        <div class="actions">
          <button class="btn btn-play" onclick="playAudio('<%= r.file %>', this)">▶ 播放</button>
          <a class="btn btn-download" href="/download/<%= r.file %>">下载</a>
        </div>
      </div>
      <% }); %>
    </div>

    <a class="btn-back" href="/">← 继续生成</a>

    <div class="footer">
      每段音频自动添加 4 拍预备拍
    </div>
  </div>

  <audio id="player"></audio>
  <script>
    const player = document.getElementById('player')
    function playAudio(file, btn) {
      if (player.src && player.src.includes(file) && !player.paused) {
        player.pause()
        btn.textContent = '▶ 播放'
        return
      }
      player.src = '/download/' + file
      player.play()
      btn.textContent = '⏹ 暂停'
      player.onended = () => { btn.textContent = '▶ 播放' }
    }
  </script>
</body>
</html>
